    "@opentui/solid": "^0.1.10",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  }
}
