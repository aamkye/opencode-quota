{
  "name": "@aamkye/opencode-quota-zai-cp",
  "version": "1.0.0",
  "description": "OpenCode TUI sidebar plugin for GLM rate limit reset countdown",
  "type": "module",
  "exports": {
    "./tui": "./dist/opencode-quota-zai.tsx"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "test": "node tests/compile-shared.mjs && node --test tests/*.test.mjs",
